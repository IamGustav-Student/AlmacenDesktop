# Puerto donde correrá el servidor local
PORT=3000

# String de conexión a base de datos (PostgreSQL: Supabase o Neon)
# Ejemplo: postgres://usuario:password@host:5432/nombre_db
DATABASE_URL=your_postgres_connection_string_here

# Clave secreta compartida para la firma criptográfica HMAC-SHA256 (Debe coincidir con la de C#)
LICENSE_HMAC_SECRET=hexastrategy_vendemax_secret_key_default

# Configuración de Servidor SMTP para envío de correos con licencias
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_email@gmail.com
SMTP_PASS=tu_app_password_gmail
SMTP_FROM=tu_usuario_email@gmail.com

# Token de acceso de Mercado Pago para verificar transacciones reales
MP_ACCESS_TOKEN=your_mercado_pago_access_token_here
